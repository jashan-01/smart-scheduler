# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_agent_id

# Google Calendar - Service Account (domain-wide delegation, for org mode)
# Paste the full JSON key as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google OAuth (for personal mode)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo Users (Google Workspace accounts, for org mode)
NEXT_PUBLIC_USER_1_EMAIL=jashan@yourdomain.com
NEXT_PUBLIC_USER_1_NAME=Jashan
NEXT_PUBLIC_USER_2_EMAIL=alice@yourdomain.com
NEXT_PUBLIC_USER_2_NAME=Alice
NEXT_PUBLIC_USER_3_EMAIL=bob@yourdomain.com
NEXT_PUBLIC_USER_3_NAME=Bob
